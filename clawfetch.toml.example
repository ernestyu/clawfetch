# Example clawfetch configuration.
# In the OpenClaw / ClawHub skill, the formal config lives at:
#   skills/clawfetch/clawfetch.toml

[flaresolverr]
# Keep disabled by default. Set enabled = true and provide url only when using
# FlareSolverr for Cloudflare / bot challenge pages.
enabled = false
# url = "http://127.0.0.1:8191"
max_timeout_ms = 60000
